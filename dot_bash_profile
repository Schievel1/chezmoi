# /etc/skel/.bash_profile

# This file is sourced by bash for login shells.  The following line
# runs your .bashrc and is recommended by the bash info pages.
if [[ -f ~/.bashrc ]] ; then
	. ~/.bashrc
fi

export DOOMDIR=${XDG_CONFIG_HOME}/doom

export PATH="$HOME/.config/emacs/bin:$HOME/.local/bin:$HOME/bin:$HOME/dev/platform-tools:$JAVA_HOME/bin:$PATH"
if [ -d "$HOME/.local/bin" ] ; then
    PATH="$HOME/.local/bin:$PATH"
fi
export PATH="/home/$USER/go/bin:/home/$USER/.local/bin:$NPM_CONFIG_PREFIX/bin:$PATH"

export GPG_TTY=$TTY
export EDITOR="emacsclient -t -r -n -a emacs -nw"

export FZF_DEFAULT_OPTS="--layout=reverse --color=dark --cycle --ignore-case --height 20 --bind tab:accept"

export DOOMDIR="$HOME/.config/doom"

export EMACS_SOCKET_NAME="/tmp/emacs$UID/server"

export HISTCONTROL="ignoredups:ignorespace"

export PAGER=moor

export GIT_EDITOR=vi

source /home/pascal/.config/broot/launcher/bash/br

. "$HOME/.cargo/env"
